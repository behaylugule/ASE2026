DJANGO_SECRET_KEY=change-me-in-production
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,backend
CORS_ALLOWED_ORIGINS=http://localhost:3000

POSTGRES_USER=ase
POSTGRES_PASSWORD=ase
POSTGRES_DB=ase

# OpenAI for answer generation (required for chat answers)
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4o-mini

# Embedding dimension must match EMBEDDING_MODEL (MiniLM = 384)
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384

RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
RETRIEVE_TOP_K=10
RERANK_TOP_K=3
CHAT_HISTORY_LIMIT=20

# Local venv (no Docker): install CPU PyTorch before other backend deps so you do not pull CUDA wheels:
#   pip install torch --index-url https://download.pytorch.org/whl/cpu
#   pip install -r backend/requirements.txt
